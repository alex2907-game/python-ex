i.	Pie Chart
ii.	Scatter Plot

1. Pie Chart
Code:

import matplotlib.pyplot as plt

# ----- Pie Chart -----
labels = ['Python', 'Java', 'C++', 'JavaScript']
sizes = [40, 25, 20, 15]
colors = ['gold', 'lightblue', 'lightgreen', 'pink']

plt.figure(figsize=(6, 6))
plt.pie(sizes, labels=labels, colors=colors, autopct='%1.1f%%', startangle=90)
plt.title('Programming Language Usage')
plt.show()

2. Scatter Plot
Code:

import matplotlib.pyplot as plt

# Data: Study hours and corresponding marks of students
study_hours = [1, 2, 3, 4, 5, 6, 7, 8]
marks = [35, 40, 50, 55, 65, 70, 80, 90]

plt.figure(figsize=(7, 5))

# Scatter plot with customization
plt.scatter(study_hours, marks, color='blue', marker='o', s=100, edgecolors='black')

# Labels and title
plt.xlabel('Study Hours per Day')
plt.ylabel('Marks Obtained')
plt.title('Student Marks as per Study Hours')

# Grid for better readability
plt.grid(True)

plt.show()
